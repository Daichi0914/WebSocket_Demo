# --- Environment ---
APP_ENV=dev
NODE_ENV=development
RESTART_POLICY=no
MYSQL_VOLUME_NAME=chat-dev_chat_mysql_dev_data
REDIS_VOLUME_NAME=chat-dev_chat_redis_dev_data

# --- Nginx ---
NGINX_PORT=8080

# --- Database ---
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=chatdb
MYSQL_USER=chat_user
MYSQL_PASSWORD=your_app_password_here
MYSQL_DSN=chat_user:your_app_password_here@tcp(mysql:3306)/chatdb?parseTime=true&loc=Local
MYSQL_EXPOSE=3306

# --- Redis ---
REDIS_ADDR=redis:6379
REDIS_EXPOSE=6379

# --- Frontend ---
FRONTEND_TARGET=dev
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
