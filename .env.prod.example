# --- Database ---
MYSQL_ROOT_PASSWORD=your_secure_password_here
MYSQL_DATABASE=chatdb
MYSQL_DSN=root:your_secure_password_here@tcp(mysql:3306)/chatdb?parseTime=true&loc=Local

# --- Redis ---
REDIS_ADDR=redis:6379

# --- Frontend (Public) ---
# おうちサーバーのIPアドレス（例: http://192.168.11.65）
NEXT_PUBLIC_API_URL=http://your_server_ip
NEXT_PUBLIC_WS_URL=ws://your_server_ip/ws
