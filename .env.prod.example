# --- Environment ---
APP_ENV=prod
NODE_ENV=production
RESTART_POLICY=always
MYSQL_VOLUME_NAME=chat-prod_chat_mysql_prod_data

# --- Nginx ---
NGINX_PORT=80

# --- Database ---
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=chatdb
MYSQL_USER=chat_user
MYSQL_PASSWORD=your_secure_app_password_here
MYSQL_DSN=chat_user:your_secure_app_password_here@tcp(mysql:3306)/chatdb?parseTime=true&loc=Local
MYSQL_EXPOSE=127.0.0.1:3306

# --- Redis ---
REDIS_ADDR=redis:6379
REDIS_EXPOSE=127.0.0.1:6379

# --- Frontend ---
FRONTEND_TARGET=runner
NEXT_PUBLIC_API_URL=http://your_server_ip
NEXT_PUBLIC_WS_URL=ws://your_server_ip/ws
