# --- Environment ---
APP_ENV=stg
NODE_ENV=production
RESTART_POLICY=always

# --- Nginx ---
NGINX_PORT=8080

# --- Database ---
MYSQL_ROOT_PASSWORD=your_secure_stg_root_password_here
MYSQL_DATABASE=chatdb_stg
MYSQL_USER=chat_user
MYSQL_PASSWORD=your_secure_stg_app_password_here
MYSQL_DSN=chat_user:your_secure_stg_app_password_here@tcp(mysql:3306)/chatdb_stg?parseTime=true&loc=Local
MYSQL_EXPOSE=127.0.0.1:3306

# --- Redis ---
REDIS_ADDR=redis:6379
REDIS_EXPOSE=127.0.0.1:6379

# --- Frontend ---
FRONTEND_TARGET=runner
NEXT_PUBLIC_API_URL=http://your_server_ip:8080
NEXT_PUBLIC_WS_URL=ws://your_server_ip:8080/ws
